# GPS Shield — Environment Variables
# Copy to .env and fill in values. Never commit .env.

# PostgreSQL (use Neon free tier in production)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/gps_shield

# OpenSky Network (register free at opensky-network.org)
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# Backend
CORS_ORIGINS=http://localhost:3000
POLL_INTERVAL_SECONDS=22
LOG_LEVEL=INFO

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
