# GPS Shield — Environment Variables
# Copy to .env and fill in values. NEVER commit .env files.

# ============================================================
# Backend (FastAPI)
# ============================================================

# PostgreSQL async URL. Use Neon free tier in production.
# Production example (sslmode required):
#   postgresql+asyncpg://user:pass@host.neon.tech/db?ssl=true
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/gps_shield

# OpenSky Network (optional — only needed for real-time polling).
# Register free at opensky-network.org.
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# Live polling loop (disable in demo deployments to reduce cost).
LIVE_POLLING_ENABLED=false
POLL_INTERVAL_SECONDS=60

# Comma-separated list of allowed CORS origins.
# Production: set to your Vercel URL, e.g. https://gps-shield.vercel.app
CORS_ORIGINS=http://localhost:3000

# Rate limit per client IP per minute for public API endpoints.
RATE_LIMIT=60/minute

# Log level (DEBUG, INFO, WARNING, ERROR).
LOG_LEVEL=INFO

# ============================================================
# Frontend (Next.js)
# ============================================================

# Backend API base URL. Must be reachable from the browser.
# Production: https://your-backend.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public site URL for OpenGraph metadata and SEO.
# Production: https://gps-shield.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
